{
  "python-envs.defaultEnvManager": "renan-r-santos.pixi-code:pixi",
  "python-envs.defaultPackageManager": "renan-r-santos.pixi-code:pixi",
  "python.defaultInterpreterPath": "${workspaceFolder}/.pixi/envs/default/bin/python",
  "jupyter.kernels.trusted": [
    "${workspaceFolder}/.pixi/envs/default/share/jupyter/kernels/python3/kernel.json"
  ],
  "ruff.nativeServer": "on",
  "ruff.path": [
    "${workspaceFolder}/.pixi/envs/default/bin/ruff"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticMode": "workspace",
  "errorLens.enabled": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 2000,
  "notebook.output.textLineLimit": 20,
  "notebook.output.scrolling": true
}
